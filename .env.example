# Gmail credentials (App Password required — enable 2-Step Verification first)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_16_char_app_password

# Recipient email for contact form messages
MAIL_TO=your_email@gmail.com

# Server port
PORT=5000

# Allowed frontend origin for CORS
# In production: set this to your Vercel frontend URL e.g. https://your-portfolio.vercel.app
CLIENT_URL=http://localhost:5174

# Frontend API base URL (used by Vite — prefix VITE_ is required)
# In production: set this to your deployed backend URL e.g. https://your-backend.onrender.com
# This fixes PDF downloads — download buttons call the backend which sets Content-Disposition headers
VITE_API_URL=http://localhost:5000
